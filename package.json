{
  "name": "psy_mind",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "CC-BY-SA-4.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest --environment jsdom",
    "type-check": "tsc --noEmit",
    "analyze": "vite build --mode production",
    "analyze:ui": "open dist/stats.html",
    "ci": "npm run type-check && npm run lint && npm run test:ci && npm run build",
    "test:ci": "vitest run --environment jsdom --coverage --reporter=dot",
    "test:coverage": "vitest run --environment jsdom --coverage --reporter=lcov",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:prompts": "promptfoo eval -c prompt-tests/promptfooconfig.yaml",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port $PORT"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.51.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@sentry/react": "^10.55.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "framer-motion": "^12.23.24",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "langfuse": "^3.38.20",
    "posthog-js": "^1.376.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^13.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.6",
    "react-simple-code-editor": "^0.14.1",
    "react-textarea-autosize": "^8.5.9",
    "sonner": "^2.0.7",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zod": "^3.22.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.4",
    "baseline-browser-mapping": "^2.10.25",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "promptfoo": "^0.121.13",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.2",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0",
    "minimatch": "9.0.7",
    "magic-string": "^0.30.21",
    "source-map": "^0.7.6"
  },
  "vitest": {
    "setupFiles": [
      "src/setupTests.ts"
    ],
    "globals": true
  }
}
